# .env.production.example
#
# Copy to .env and fill in all required values before deploying.
# NEVER commit .env to version control.
#
# Required vars are marked [REQUIRED].
# Optional vars have defaults shown.

# ── Core ─────────────────────────────────────────────────────────────────────

# [REQUIRED] Secret key for JWT signing. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Must NOT be the default value "dev-secret" in production.
JWT_SECRET=

# [REQUIRED] Database connection URL.
# PostgreSQL (recommended for production):
#   postgresql+asyncpg://user:password@host:5432/celerp
# SQLite (dev/testing only):
#   sqlite+aiosqlite:///celerp.db
DATABASE_URL=

# Allow insecure JWT (dev only - never set in production)
# ALLOW_INSECURE_JWT=false

# ── Gateway / Cloud Relay ─────────────────────────────────────────────────────

# Gateway base URL (used for SaaS features: AI, connectors, backup relay)
# Leave blank to disable SaaS features.
GATEWAY_URL=

# [REQUIRED if GATEWAY_URL is set] Token for gateway authentication.
GATEWAY_TOKEN=

# ── Stripe Billing ───────────────────────────────────────────────────────────

# Required for SaaS subscription billing (Cloud and Cloud+AI tiers).
# Leave blank to disable payment features.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_CLOUD=
STRIPE_PRICE_ID_CLOUD_AI=

# ── Email / SMTP ─────────────────────────────────────────────────────────────

# Required to send invoice PDFs, subscription confirmations, doc-sent events.
# Leave blank to disable email notifications (silent mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Celerp              # Display name shown to recipients, e.g. "Acme ERP"
SMTP_TLS=true

# ── Storage ───────────────────────────────────────────────────────────────────

# Storage backend for file attachments and exports.
# Options: local (default), s3
STORAGE_BACKEND=local

# [REQUIRED if STORAGE_BACKEND=s3]
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=ap-southeast-1

# Local storage path (used when STORAGE_BACKEND=local)
# STORAGE_LOCAL_PATH=./storage

# ── Modules ───────────────────────────────────────────────────────────────────

# Path to the modules directory (default: default_modules alongside the app).
MODULE_DIR=default_modules

# Comma-separated list of enabled modules.
# Leave blank to load all modules in MODULE_DIR.
# ENABLED_MODULES=celerp-manufacturing,celerp-labels

# ── Public URL ───────────────────────────────────────────────────────────────

# Public-facing base URL (used in share links, PDF footers, P2P doc exchange).
CELERP_PUBLIC_URL=https://yourdomain.com

# ── Security ─────────────────────────────────────────────────────────────────

# Allowed CORS origins (comma-separated). Defaults to CELERP_PUBLIC_URL.
# CORS_ORIGINS=https://yourdomain.com

# Cookie settings
COOKIE_SECURE=true      # Set to true when serving over HTTPS (required in production)
# COOKIE_SAMESITE=lax

# ── Rate Limiting ─────────────────────────────────────────────────────────────

# Redis URL for distributed rate limiting (optional).
# Without Redis, rate limits are per-process only (not shared across workers).
REDIS_URL=redis://localhost:6379/0

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Deployment Notes ─────────────────────────────────────────────────────────
#
# Before going live:
# 1. Set JWT_SECRET to a random 256-bit hex string (see above)
# 2. Set DATABASE_URL to a PostgreSQL connection string
# 3. Run as superuser: alembic upgrade head
# 3.5. Grant privileges to the app user (if app user != migration superuser):
#      python scripts/pg_grant.py --db-url postgresql://superuser:pass@host/celerp --app-user celerp_user
#      (Required: INSERT on ledger and all other tables needs USAGE on sequences)
# 4. Set CELERP_PUBLIC_URL to your domain
# 5. Configure HTTPS (Caddy / nginx reverse proxy)
# 6. Set COOKIE_SECURE=true
# 7. Configure SMTP for email notifications
# 8. Configure Stripe for billing (if using SaaS tier)
# 9. Set MODULE_DIR and ENABLED_MODULES as needed
